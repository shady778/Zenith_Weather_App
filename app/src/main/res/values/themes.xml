<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="Theme.Zenith" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Splash Screen theme. -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Background of the splash screen. -->
        <item name="windowSplashScreenBackground">@color/splash_bg</item>
        <!-- Zenith logo shown on the system splash screen before the app loads. -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
        <!-- Icon background color (matches the logo's navy bg). -->
        <item name="windowSplashScreenIconBackgroundColor">@color/splash_bg</item>
        <!-- Theme to use after the splash screen is done. -->
        <item name="postSplashScreenTheme">@style/Theme.Zenith</item>
    </style>

    <style name="Theme.Zenith.Transparent" parent="Theme.Zenith">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>
</resources>